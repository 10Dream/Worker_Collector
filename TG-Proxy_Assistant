        const ALL_PROTOCOLS = [
            'vmess', 'vless', 'trojan', 'ss', 'ssr', 'tuic', 'hysteria', 'hysteria2', 
            'juicity', 'snell', 'anytls', 'ssh', 'wireguard', 'socks', 'cloudflare'
