async function handleTelegramUpdate(update, env, settings, logger) {
  if (!settings.bot_mode_enabled) return;

  if (update.message && update.message.text === "/start") {
    const chatId = update.message.chat.id;
    const keyboard = {
      inline_keyboard: [
        [{ text: "🚀 دریافت پروکسی 🚀", callback_data: "menu_proxies" }],
        [{ text: "🌐 دریافت کانفیگ 🌐", callback_data: "menu_configs" }]
      ]
    };
    await sendTelegramMessage(env.BOT_TOKEN, chatId, "سلام! به ربات سیستم هوشمند خوش آمدید.\nلطفاً سرویس مورد نظر خود را انتخاب کنید:", keyboard);
  } 
  
  else if (update.callback_query) {
    const cb = update.callback_query;
    const chatId = cb.message.chat.id;
    const data = cb.data;
    const msgId = cb.message.message_id;

    if (settings.rl_enabled && (data.startsWith("get_") || data.startsWith("cfg_get_"))) {
      const rlKey = `rl_${chatId}`;
      let rlData = await env.PROXY_KV.get(rlKey, { type: 'json' });
      if (!rlData) {
        await env.PROXY_KV.put(rlKey, JSON.stringify({ count: 1 }), { expirationTtl: settings.rl_time * 60 });
      } else {
        if (rlData.count >= settings.rl_reqs) {
          await fetch(`https://api.telegram.org/bot${env.BOT_TOKEN}/answerCallbackQuery?callback_query_id=${cb.id}&text=${encodeURIComponent("⚠️ شما به محدودیت ضداسپم رسیده‌اید. لطفا بعدا تلاش کنید.")}&show_alert=true`);
          return;
        }
        await env.PROXY_KV.put(rlKey, JSON.stringify({ count: rlData.count + 1 }), { expirationTtl: settings.rl_time * 60 });
      }
    }

    await fetch(`https://api.telegram.org/bot${env.BOT_TOKEN}/answerCallbackQuery?callback_query_id=${cb.id}`);

    if (data === "menu_proxies") {
      const keyboard = {
        inline_keyboard: [
          [{ text: "💻 ویندوز (ویژه)", callback_data: "get_proxy_win" }, { text: "📱 عادی (موبایل)", callback_data: "get_proxy_reg" }],
          [{ text: "🔀 ترکیبی (میکس)", callback_data: "get_proxy_mix" }],
          [{ text: "🔙 بازگشت", callback_data: "menu_back" }]
        ]
      };
      await editTelegramMessage(env.BOT_TOKEN, chatId, msgId, "نوع پروکسی را انتخاب کنید (۲۰ عدد):", keyboard);
    } 
    else if (data.startsWith("get_proxy_")) {
      const type = data.replace("get_proxy_", "get_");
      await sendProxiesToUser(chatId, type, env, settings.sources, logger);
    }
    
    else if (data === "menu_configs") {
      let inline_keyboard = [];
      let row = [];
      let activeProtocols = Object.keys(settings.protocols).filter(p => settings.protocols[p].enabled);
      
      activeProtocols.forEach((p, index) => {
        let btnText = p === 'cloudflare' ? '☁️ کلادفلر (ویژه)' : p.toUpperCase();
        row.push({ text: btnText, callback_data: `cfg_sel_${p}` });
        if (row.length === 2 || index === activeProtocols.length - 1) {
          inline_keyboard.push(row);
          row = [];
        }
      });
      inline_keyboard.push([{ text: "🔙 بازگشت", callback_data: "menu_back" }]);

      if (activeProtocols.length === 0) {
        await editTelegramMessage(env.BOT_TOKEN, chatId, msgId, "هیچ پروتکلی در سیستم فعال نیست.", { inline_keyboard });
      } else {
        await editTelegramMessage(env.BOT_TOKEN, chatId, msgId, "پروتکل مورد نظر را انتخاب کنید:", { inline_keyboard });
      }
    }
    else if (data.startsWith("cfg_sel_")) {
      const proto = data.replace("cfg_sel_", "");
      const protoName = proto === 'cloudflare' ? 'کلادفلر' : proto.toUpperCase();
      const keyboard = {
        inline_keyboard: [
          [{ text: "۵ عدد", callback_data: `cfg_get_${proto}_5` }, { text: "۱۰ عدد", callback_data: `cfg_get_${proto}_10` }],
          [{ text: "۲۰ عدد (فایل)", callback_data: `cfg_get_${proto}_20` }, { text: "۵۰ عدد (فایل)", callback_data: `cfg_get_${proto}_50` }],
          [{ text: "۱۰۰ عدد (فایل)", callback_data: `cfg_get_${proto}_100` }, { text: "۵۰۰ عدد (فایل)", callback_data: `cfg_get_${proto}_500` }],
          [{ text: "حداکثر (فایل)", callback_data: `cfg_get_${proto}_max` }],
          [{ text: "🔙 بازگشت", callback_data: "menu_configs" }]
        ]
      };
      await editTelegramMessage(env.BOT_TOKEN, chatId, msgId, `تعداد کانفیگ ${protoName} را انتخاب کنید:`, keyboard);
    }
    else if (data.startsWith("cfg_get_")) {
      const parts = data.split("_");
      const proto = parts[2];
      const qtyParam = parts[3];
      const qty = qtyParam === 'max' ? Infinity : parseInt(qtyParam);
      
      await sendConfigsToUser(chatId, proto, qty, env, settings.config_sources, logger);
    }
    
    else if (data === "menu_back") {
      const keyboard = {
        inline_keyboard: [
          [{ text: "🚀 دریافت پروکسی 🚀", callback_data: "menu_proxies" }],
          [{ text: "🌐 دریافت کانفیگ 🌐", callback_data: "menu_configs" }]
        ]
      };
      await editTelegramMessage(env.BOT_TOKEN, chatId, msgId, "سلام! به ربات سیستم هوشمند خوش آمدید.\nلطفاً سرویس مورد نظر خود را انتخاب کنید:", keyboard);
    }
  }
}

async function sendProxiesToUser(chatId, type, env, sources, logger) {
  await sendTelegramMessage(env.BOT_TOKEN, chatId, "⏳ در حال استخراج و بررسی پروکسی...");
  const { standard, windows } = await fetchAndFilterProxies(sources);
  let selection = [];
  const REQ_AMOUNT = 20;

  if (type === "get_win") {
    shuffleArray(windows);
    selection = windows.slice(0, REQ_AMOUNT).map(l => `<a href="${cleanLink(l)}">پروکسی ویندوز</a>`);
  } else if (type === "get_reg") {
    shuffleArray(standard);
    selection = standard.slice(0, REQ_AMOUNT).map(l => `<a href="${cleanLink(l)}">پروکسی</a>`);
  } else if (type === "get_mix") {
    shuffleArray(windows);
    shuffleArray(standard);
    const winList = windows.slice(0, REQ_AMOUNT / 2).map(l => `<a href="${cleanLink(l)}">پروکسی ویندوز</a>`);
    const regList = standard.slice(0, REQ_AMOUNT / 2).map(l => `<a href="${cleanLink(l)}">پروکسی</a>`);
    selection = [...winList, ...regList];
    shuffleArray(selection);
  }

  if (selection.length === 0) {
    await sendTelegramMessage(env.BOT_TOKEN, chatId, "❌ پروکسی یافت نشد.");
    return;
  }
  await sendTelegramMessage(env.BOT_TOKEN, chatId, `✅ لیست پروکسی‌های شما:\n\n${selection.join("\n")}`);
}

async function sendConfigsToUser(chatId, proto, qty, env, sources, logger) {
  await sendTelegramMessage(env.BOT_TOKEN, chatId, "⏳ در حال استخراج هوشمند کانفیگ...");
  const allConfigs = await fetchAndFilterConfigs(sources);
  let available = allConfigs[proto] || [];
  
  if (available.length === 0) {
    await sendTelegramMessage(env.BOT_TOKEN, chatId, `❌ کانفیگ یافت نشد.`);
    return;
  }

  shuffleArray(available);
  const selection = available.slice(0, qty === Infinity ? available.length : qty);
  const protoDisplay = proto === 'cloudflare' ? 'Cloudflare' : proto.toUpperCase();

  if (selection.length > 10) {
    const fileContent = selection.join("\n");
    let filenameStr = qty === Infinity ? 'MAX' : selection.length;
    const filename = `${protoDisplay}_Configs_${filenameStr}_${new Date().getTime()}.txt`;
    const caption = `✅ تعداد ${selection.length} کانفیگ ${protoDisplay}`;
    
    const success = await sendTelegramDocument(env.BOT_TOKEN, chatId, caption, filename, fileContent);
    if (!success) await sendTelegramMessage(env.BOT_TOKEN, chatId, "❌ خطا در ارسال فایل تلگرام.");
  } else {
    const text = `✅ <b>لیست کانفیگ‌های ${protoDisplay}:</b>\n\n<code>${selection.join("\n\n")}</code>\n\n👇 <i>برای کپی کلیک کنید</i>`;
    await sendTelegramMessage(env.BOT_TOKEN, chatId, text);
  }
}

// ==========================================
// منطق ارسال خودکار کانال (Cron)
// ==========================================
async function processAutoPost(env, settings, logger) {
  if (!env.PROXY_KV || !env.BOT_TOKEN) {
    await logger.log("ERROR", "KV یا توکن ربات تنظیم نشده است.");
    return;
  }

  if (!settings.channel_mode_enabled || !settings.channel_id) return;

  await processProxiesForChannel(env, settings, logger);
  await processConfigsForChannel(env, settings, logger);
}

async function processProxiesForChannel(env, settings, logger) {
  const { standard, windows } = await fetchAndFilterProxies(settings.sources);
  let sentHistory = [];
  const historyData = await env.PROXY_KV.get("sent_proxies");
  if (historyData) sentHistory = JSON.parse(historyData);
  const sentSet = new Set(sentHistory);

  let newStandard = standard.filter(p => !sentSet.has(p));
  let newWindows = windows.filter(p => !sentSet.has(p));

  if (newStandard.length === 0 && newWindows.length === 0) return;

  shuffleArray(newStandard);
  shuffleArray(newWindows);

  const totalToSend = settings.post_qty;
  let targetHalf = Math.floor(totalToSend / 2);
  let selectedWindows = newWindows.slice(0, targetHalf);
  let remaining = totalToSend - selectedWindows.length;
  let selectedStandard = newStandard.slice(0, remaining);

  if (selectedStandard.length < remaining) {
    let extra = remaining - selectedStandard.length;
    selectedWindows = selectedWindows.concat(newWindows.slice(targetHalf, targetHalf + extra));
  }

  const finalSelection = [...selectedStandard, ...selectedWindows];
  if (finalSelection.length === 0) return;

  // CHUNKING LOGIC FOR PROXIES (محدودیت پیام‌های طولانی)
  let successfullySent = [];
  const chunkSize = 25;

  for (let i = 0; i < finalSelection.length; i += chunkSize) {
    const chunk = finalSelection.slice(i, i + chunkSize);
    let messageText = "🚀 <b>پروکسی‌های جدید</b>\n\n";
    chunk.forEach(link => { 
        let isWin = isWindowsCompatible(link);
        messageText += `<a href="${cleanLink(link)}">${isWin ? 'پروکسی ویندوز' : 'پروکسی عادی'}</a>\n`; 
    });

    const success = await sendTelegramMessage(env.BOT_TOKEN, settings.channel_id, messageText);
    if (success) successfullySent.push(...chunk);
    await new Promise(r => setTimeout(r, 500)); // Delay between chunks
  }

  if (successfullySent.length > 0) {
    const updatedHistory = [...sentHistory, ...successfullySent].slice(-3000);
    await env.PROXY_KV.put("sent_proxies", JSON.stringify(updatedHistory));
    await logger.log("INFO", `ارسال پروکسی به کانال: ${successfullySent.length} عدد.`);
  }
}

async function processConfigsForChannel(env, settings, logger) {
  const configsByProto = await fetchAndFilterConfigs(settings.config_sources);
  
  let sentHistory = [];
  const historyData = await env.PROXY_KV.get("sent_configs");
  if (historyData) sentHistory = JSON.parse(historyData);
  const sentSet = new Set(sentHistory);

  let finalSelection = [];

  for (const proto of ALL_PROTOCOLS) {
    if (settings.protocols[proto] && settings.protocols[proto].enabled) {
      const qtyRequired = parseInt(settings.protocols[proto].qty) || 0;
      if (qtyRequired > 0) {
        let available = configsByProto[proto] || [];
        let newAvailable = available.filter(c => !sentSet.has(c));
        shuffleArray(newAvailable);
        finalSelection = finalSelection.concat(newAvailable.slice(0, qtyRequired));
      }
    }
  }

  if (finalSelection.length === 0) return;

  // CHUNKING LOGIC FOR CONFIGS (برای جلوگیری از خطای طول 4096 کاراکتر تلگرام)
  let successfullySentConfigs = [];
  const chunkSize = 10; // ارسال حداکثر ۱۰ کانفیگ در هر پیام

  for (let i = 0; i < finalSelection.length; i += chunkSize) {
    const chunk = finalSelection.slice(i, i + chunkSize);
    let messageText = "🌐 <b>کانفیگ‌های جدید</b>\n\n";
    messageText += `<code>${chunk.join("\n\n")}</code>\n\n`;
    messageText += "👇 <i>برای کپی کلیک کنید</i>";

    const success = await sendTelegramMessage(env.BOT_TOKEN, settings.channel_id, messageText);
    if (success) {
        successfullySentConfigs.push(...chunk);
    }
    await new Promise(r => setTimeout(r, 500)); // Delay between chunks to prevent flooding
  }

  if (successfullySentConfigs.length > 0) {
    const updatedHistory = [...sentHistory, ...successfullySentConfigs].slice(-5000);
    await env.PROXY_KV.put("sent_configs", JSON.stringify(updatedHistory));
    await logger.log("INFO", `ارسال کانفیگ به کانال: ${successfullySentConfigs.length} عدد.`);
  } else {
    await logger.log("ERROR", "خطا در ارسال کانفیگ به کانال. ربات در کانال ادمین نیست یا کانال اشتباه است.");
  }
}

// ==========================================
// توابع ارتباط با تلگرام و پروکسی
// ==========================================
async function sendTelegramMessage(token, chatId, text, keyboard = null) {
  try {
    const body = { chat_id: chatId, text: text, parse_mode: 'HTML', disable_web_page_preview: true };
    if (keyboard) body.reply_markup = keyboard;
    const res = await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
    });
    return res.ok;
  } catch (e) { return false; }
}

async function editTelegramMessage(token, chatId, msgId, text, keyboard = null) {
  try {
    const body = { chat_id: chatId, message_id: msgId, text: text, parse_mode: 'HTML', disable_web_page_preview: true };
    if (keyboard) body.reply_markup = keyboard;
    await fetch(`https://api.telegram.org/bot${token}/editMessageText`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
    });
  } catch (e) {}
}

async function sendTelegramDocument(token, chatId, caption, filename, fileContent) {
  try {
    const formData = new FormData();
    formData.append('chat_id', chatId);
    formData.append('caption', caption);
    formData.append('parse_mode', 'HTML');
    formData.append('document', new Blob([fileContent], { type: 'text/plain' }), filename);

    const res = await fetch(`https://api.telegram.org/bot${token}/sendDocument`, {
      method: 'POST', body: formData
    });
    return res.ok;
  } catch (e) { return false; }
}

async function fetchAndFilterProxies(sources) {
  let standard = [], windows = [], allSet = new Set();
  for (const url of sources) {
    try {
      const res = await fetch(url);
      if (res.ok) {
        const text = await res.text();
        text.split('\n').map(l => l.trim()).forEach(line => {
          if (line.startsWith('tg://') || line.startsWith('https://t.me/')) allSet.add(line);
        });
      }
    } catch (e) {}
  }
  for (const proxy of allSet) {
    if (isWindowsCompatible(proxy)) windows.push(proxy);
    else standard.push(proxy);
  }
  return { standard, windows };
}

function isWindowsCompatible(link) {
  try {
    const secretMatch = link.match(/secret=([a-zA-Z0-9%_\-]+)/);
    if (!secretMatch) return false;
    const secret = secretMatch[1].toLowerCase();
    if (secret.includes('%') || secret.includes('_') || secret.includes('-')) return false;
    if (secret.startsWith('ee')) return false;
    const actualSecret = secret.startsWith('dd') ? secret.substring(2) : secret;
    if (!/^[0-9a-f]{32}$/.test(actualSecret)) return false;
    return true;
  } catch (error) { return false; }
}

function shuffleArray(array) {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
}

function cleanLink(link) {
  return link.replace(/[()\[\]\s!.,;'"]+$/, '');
}

