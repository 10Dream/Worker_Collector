                    <input type="number" id="qty_\${p}" min="0" placeholder="تعداد">
                </div>\`
            }).join('');
        };

        async function loadData() {
            try {
                initProtocolsGrid();
                const sRes = await fetch('/api/settings');
                const sData = await sRes.json();
                
                document.getElementById('bot_mode').checked = sData.bot_mode_enabled;
                document.getElementById('channel_mode').checked = sData.channel_mode_enabled;
                document.getElementById('rl_enabled').checked = sData.rl_enabled || false;
                
                document.getElementById('admin_chat_id').value = sData.admin_chat_id || '';
                document.getElementById('channel_id').value = sData.channel_id;
                document.getElementById('post_qty').value = sData.post_qty;
                document.getElementById('rl_time').value = sData.rl_time || 60;
                document.getElementById('rl_reqs').value = sData.rl_reqs || 5;
                
                document.getElementById('sources').value = sData.sources.join('\\n');
                document.getElementById('config_sources').value = (sData.config_sources || []).join('\\n');

                if (sData.protocols) {
                    ALL_PROTOCOLS.forEach(p => {
                        if (sData.protocols[p]) {
                            document.getElementById(\`chk_\${p}\`).checked = sData.protocols[p].enabled;
                            document.getElementById(\`qty_\${p}\`).value = sData.protocols[p].qty;
                        }
                    });
                }
                await loadLogs();
            } catch (e) { showToast('خطا در بارگذاری', 'error'); }
        }

        async function loadLogs() {
            try {
                const res = await fetch('/api/logs');
                const data = await res.json();
                renderHealth(data.health);
                renderLogs(data.logs);
            } catch (e) { console.error(e); }
        }

        async function saveSettings() {
            let protocolsData = {};
            ALL_PROTOCOLS.forEach(p => {
                protocolsData[p] = {
                    enabled: document.getElementById(\`chk_\${p}\`).checked,
                    qty: parseInt(document.getElementById(\`qty_\${p}\`).value) || 0
                };
            });

            const payload = {
                bot_mode_enabled: document.getElementById('bot_mode').checked,
                channel_mode_enabled: document.getElementById('channel_mode').checked,
                rl_enabled: document.getElementById('rl_enabled').checked,
                admin_chat_id: document.getElementById('admin_chat_id').value.trim(),
