            if(confirm('تاریخچه جلوگیری از ارسال تکراری کاملا پاک شود؟')) {
                await fetch('/api/clear-history');
                showToast('تاریخچه پاک شد');
                loadLogs();
            }
        }

        window.onload = loadData;
        setInterval(loadLogs, 30000);
    </script>
</body>
</html>`;
